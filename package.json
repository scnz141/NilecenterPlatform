{
  "name": "nile-center-platform",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist-server",
    "start": "NODE_ENV=production node dist-server/index.js",
    "preview": "vite preview --host",
    "seed:supabase": "node --import tsx scripts/seed-supabase-demo.ts",
    "qa:portals": "node scripts/qa-portals-cli.mjs",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "check:phase1-schema": "node scripts/validate-phase1-schema.mjs",
    "check:phase1-schema:runtime": "node scripts/validate-phase1-pglite.mjs",
    "check:phase1-schema:supabase": "scripts/validate-phase1-supabase.sh",
    "check:phase2-session-schema": "node scripts/validate-phase2-session-schema.mjs",
    "check:phase2-session-schema:runtime": "node scripts/validate-phase2-session-pglite.mjs",
    "check:phase2-session:supabase": "scripts/validate-phase2-session-supabase.sh",
    "check:phase2-session:postgrest": "node scripts/validate-phase2-session-postgrest.mjs",
    "check:forms-schema": "node scripts/validate-nile-forms-schema.mjs",
    "check:forms-schema:runtime": "node scripts/validate-nile-forms-pglite.mjs",
    "check:forms-phase13f1": "node scripts/validate-nile-forms-phase13f1.mjs",
    "check:forms-phase13f1:runtime": "node scripts/validate-nile-forms-phase13f1-pglite.mjs",
    "check:forms-phase13f1:supabase": "scripts/validate-nile-forms-phase13f1-supabase.sh",
    "check:forms-phase13f1:postgrest": "node scripts/validate-nile-forms-phase13f1-postgrest.mjs",
    "check:moodle-sandbox": "node --import tsx scripts/validate-moodle-sandbox.ts",
    "check:moodle-sandbox-writes": "node --import tsx scripts/validate-moodle-sandbox-writes.ts",
    "check:forms-program": "node scripts/validate-nile-forms-program-contract.mjs",
    "verify": "scripts/verify.sh",
    "codex:loop": "scripts/codex-loop.sh",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
