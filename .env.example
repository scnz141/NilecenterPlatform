VITE_APP_NAME="Nile Learn"
VITE_DEMO_AUTH_ENABLED="true"
# Server demo auth is development-only. Set true in a local .env file only.
DEMO_AUTH_ENABLED="false"
VITE_OAUTH_PORTAL_URL=""
VITE_APP_ID=""
VITE_FRONTEND_FORGE_API_KEY=""
VITE_ANALYTICS_ENDPOINT=""
VITE_ANALYTICS_WEBSITE_ID=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_ANON_KEY=""

# Server-side integration placeholders. Do not expose real secrets in client code.
# Keep memory as the default until the Phase 2 durable-session promotion gate is approved.
NILE_SESSION_REPOSITORY="memory"
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Manual Phase 2B acceptance only. Use fake data on an isolated local PostgREST
# endpoint and pass these values in the command shell, never in a deployed app.
NILE_PHASE2_SESSION_LOCAL_ONLY=""
NILE_LOCAL_SUPABASE_ANON_KEY=""
NILE_LOCAL_SUPABASE_JWT_SECRET=""
SUPABASE_PLATFORM_RECORDS_TABLE="platform_records"
SUPABASE_PLATFORM_DEMO_ENTITIES_TABLE="platform_demo_entities"
SUPABASE_PLATFORM_STATE_TABLE="platform_state_snapshots"
SUPABASE_PLATFORM_EVENTS_TABLE="platform_events"
SUPABASE_PLATFORM_STATE_ID="nile-learn-demo"
SUPABASE_DEMO_PASSWORD=""
NILE_DEMO_PASSWORD=""
# Nile Forms remains fail-closed in production unless this internal-alpha
# compatibility boundary is explicitly enabled with a 32-byte draft key.
NILE_FORMS_COMPATIBILITY_ENABLED="0"
NILE_FORMS_DRAFT_KEY=""
# Phase 13F1 normalized persistence remains unavailable until its complete
# repository, RPC-principal, key-version, and schema gates are accepted.
NILE_FORMS_NORMALIZED_PERSISTENCE_ENABLED="0"
NILE_FORMS_REPOSITORY="memory"
# Dedicated RPC-only bearer credential. The separate publishable key above is
# used only for the Supabase Data API gateway header.
NILE_FORMS_EXECUTOR_KEY=""
NILE_FORMS_RPC_CATALOG_VERSION="phase13f1-v1"
NILE_FORMS_SCHEMA_EVIDENCE_SHA256="aae2c27e6dc6ecaa48162ac03937e82e37d3cfd5c533e7a11e84d0d7725a8e63"
NILE_FORMS_LOCAL_ACCEPTANCE_ACK=""
NILE_FORMS_RPC_TIMEOUT_MS="5000"
NILE_FORMS_DRAFT_KEY_VERSION="1"
NILE_FORMS_PUBLIC_HMAC_KEY=""
NILE_FORMS_PUBLIC_HMAC_KEY_VERSION="1"
NILE_FORMS_PUBLIC_HMAC_PREVIOUS_KEY=""
NILE_FORMS_PUBLIC_HMAC_PREVIOUS_KEY_VERSION=""
NILE_FORMS_OFFLINE_MAC_KEY=""
NILE_FORMS_OFFLINE_MAC_KEY_VERSION="1"
NILE_FORMS_ALLOWED_ORIGINS=""
NILE_FORMS_TRUSTED_PROXY_CIDRS=""
NILE_FORMS_TRUSTED_PROXY_HOPS="0"
# Keep route cutover disabled until durable Forms persistence and parity gates pass.
VITE_NILE_FORMS_CUTOVER_ENABLED="0"
# Temporary server-only credential for a reviewed, finite Jotform import.
# Allowed regions: standard, eu, hipaa. Revoke the key after reconciliation.
JOTFORM_API_KEY=""
JOTFORM_API_REGION="standard"
MOODLE_BASE_URL=""
MOODLE_SERVICE=""
MOODLE_TOKEN=""
MOODLE_ALLOWED_HOSTS=""
MOODLE_READ_ONLY_ENABLED="0"
MOODLE_TIMEOUT_MS="15000"
# Local-command-only M2B synthetic proof. Keep disabled outside the approved sandbox run.
MOODLE_SANDBOX_WRITE_ENABLED="0"
MOODLE_SANDBOX_WRITE_BASE_URL=""
MOODLE_SANDBOX_WRITE_SERVICE=""
MOODLE_SANDBOX_WRITE_TOKEN=""
MOODLE_SANDBOX_WRITE_SYNTHETIC_ACK=""
MOODLE_SANDBOX_WRITE_COURSE_ID=""
MOODLE_SANDBOX_WRITE_ROLE_ID=""
